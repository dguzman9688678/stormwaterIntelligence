    <script>
        const componentData = {
            stormgpt: {
                title: 'StormGPT: AI Compliance Engine',
                description: 'StormGPT functions as a Regulatory RAG (Retrieval-Augmented Generation) system operating on an internal sealed PDF knowledge base. It handles core compliance logic, forecasting, and reporting.',
                features: {
                    Knowledge: 'Regulatory RAG System based on EPA NPDES, California CGP/IGP, and Clean Water Act.',
                    Daemons: 'Autonomous Daemon Architecture for ingestion, validation, consensus, predictive analytics, and compliance flag generation.',
                    Output: 'Generates multi-format outputs (PDF, DOCX, XLSX, KML) with regulatory compliance verification.'
                },
                subDetails: [
                    { name: 'IngestionDaemon', trigger: 'User request initiated', function: 'Pull NOAA/NWS data, process regulatory documents, SHA-256 verification.' },
                    { name: 'ValidationDaemon', trigger: 'Data loaded into system', function: 'Validate schema compliance and range verification against NOAA ADS standards.' },
                    { name: 'ConsensusDaemon', trigger: 'Valid data confirmed', function: 'Merge meteorological data with sensor inputs, resolve data conflicts.' },
                    { name: 'PredictiveAnalyticsDaemon', trigger: 'Data trends indicate risk', function: 'Generate maintenance recommendations, forecast compliance risks (BMP degradation/failure).' },
                    { name: 'ComplianceDaemon', trigger: 'Processed data available', function: 'Apply regulatory thresholds, flag violations, generate compliance status with specific citations.' },
                    { name: 'ReportDaemon', trigger: 'Processing completion confirmed', function: 'Generate multi-format outputs including PDF, DOCX, XLSX, CSV, and GIS files.' }
                ]
            },
            stormverse: {
                title: 'StormVerse: Desktop Intelligence Platform',
                description: 'The user-facing system designed with a **Field-First Architecture**. It is an Electron cross-platform desktop application built for environmental professionals working with intermittent connectivity.',
                features: {
                    Architecture: 'Frontend: Electron (Cross-platform). Backend: Dual Node.js/Python. Mapping: Leaflet/Cesium.',
                    Offline: 'Complete functionality without internet connectivity; local storage of maps, regulations, and calculation tools.',
                    Mapping: 'Interactive Map Editor with terrain overlays, slope analysis, and export/import of GeoJSON/KML files.'
                },
                subDetails: [
                    { name: 'AI BMP Assistant', function: 'Claude/OpenAI integration for contextual recommendations, weather-based risk assessment, and auto-generation of inspection notes.' },
                    { name: 'Real-time Weather', function: 'NOAA Forecast & Alerts API with live data streaming, used for a weather-driven BMP risk trigger system.' }
                ]
            },
            arcsec: {
                title: 'ARCSEC Protocol: Integrity Verification Framework',
                description: 'ARCSEC (Autonomous Record, Credential, Security, and Enforcement Control) is the governance protocol that ensures all system outputs are audit-proof and tamper-evident.',
                features: {
                    Sealing: 'SHA-256 cryptographic sealing for all documents.',
                    Audit: 'Immutable audit trail using blockchain-style ledger technology.',
                    Chain: 'Chain-of-Custody documentation for regulatory inspection and legal defensibility.'
                },
                subDetails: [
                    { name: 'Verification Process', function: 'Independent verification using a public hash, tamper detection through hash comparison, and audit trail reconstruction.' },
                    { name: 'Compliance Alignment', function: 'Meets EPA electronic submission requirements and California Water Board standards, supporting federal remediation project audits.' }
                ]
            }
        };

        const workflowData = [
            { title: 'Phase 1: Project Initialization', detail: 'StormVerse launches with project parameters. NOAA weather daemon starts data streaming, historical NCEI data is retrieved, and site-specific regulatory requirements are loaded from StormGPT.' },
            { title: 'Phase 2: Data Collection & Analysis', detail: 'Real-time weather triggers BMP risk assessments. AI BMP Assistant analyzes conditions against regulatory thresholds. Interactive mapping documents site conditions. Predictive analytics identify potential compliance issues.' },
            { title: 'Phase 3: Compliance Verification', detail: 'StormGPT processes all data against requirements. Violations are flagged with specific regulatory citations. Automated corrective action recommendations and BMP maintenance schedules are generated.' },
            { title: 'Phase 4: Documentation & Reporting', detail: 'Comprehensive compliance reports generated. Excel workbooks created with exposed formulas for verification. GIS data exported (KMZ, GeoJSON, KML). Safety documentation is generated.' },
            { title: 'Phase 5: ARCSEC Integrity Verification', detail: 'All documents receive cryptographic sealing (SHA-256). Notarization blocks are embedded. Manifest registration creates an immutable audit trail. Outputs prepared for regulatory submission.' }
        ];

        // --- GLOBAL STATE ---
        let currentLat = 34.27; // Default: Simi Valley, CA
        let currentLon = -118.73;
        let currentLocationName = "Simi Valley, CA";
        
        // --- DOM Elements ---
        const weatherWidget = document.getElementById('weather-widget');
        const updateWeatherBtn = document.getElementById('update-weather-btn');
        const locationInput = document.getElementById('location-input');
        const applyLocationBtn = document.getElementById('apply-location-btn');
        const locationStatus = document.getElementById('location-status');
        const exportGeoJsonBtn = document.getElementById('export-geojson-btn');
        const mapStatus = document.getElementById('map-status');

        // --- Leaflet Map Vars ---
        let map;
        let drawnItems;

        // --- CORE FUNCTIONS ---

        function updateStatus(element, message, isError = false) {
            element.textContent = message;
            element.classList.toggle('text-red-500', isError);
            element.classList.toggle('text-slate-500', !isError);
        }

        async function geocodeLocation(locationString) {
            updateStatus(locationStatus, `Searching for ${locationString}...`, false);
            // Nominatim API for geocoding (OpenStreetMap)
            const NOMINATIM_URL = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(locationString)}&limit=1`;
            
            try {
                const response = await fetch(NOMINATIM_URL);
                if (!response.ok) throw new Error('Geocoding API failed to respond.');
                const data = await response.json();

                if (data.length > 0) {
                    const result = data[0];
                    currentLat = parseFloat(result.lat);
                    currentLon = parseFloat(result.lon);
                    currentLocationName = result.display_name;
                    
                    updateStatus(locationStatus, `Location Set: ${currentLocationName} (${currentLat.toFixed(2)}, ${currentLon.toFixed(2)})`);
                    
                    updateMap(currentLat, currentLon);
                    fetchWeatherData(currentLat, currentLon);

                } else {
                    updateStatus(locationStatus, `Error: Location "${locationString}" not found. Try again.`, true);
                }

            } catch (error) {
                updateStatus(locationStatus, `Geocoding Error: Check browser console or network access.`, true);
            }
        }

        async function fetchWeatherData(lat, lon) {
            // Open-Meteo API for real-time forecast data
            const WEATHER_URL = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&hourly=precipitation,weather_code&current_weather=true&temperature_unit=fahrenheit&forecast_days=1&timezone=auto&timeformat=iso8601`;

            weatherWidget.innerHTML = '<p class="text-center text-slate-600 p-6">Fetching live weather data...</p>';
            
            try {
                const response = await fetch(WEATHER_URL);
                if (!response.ok) throw new Error('Weather API request failed');
                const data = await response.json();
                
                if (!data || !data.current_weather) throw new Error('Invalid weather data structure.');

                const current = data.current_weather;
                const temp = Math.round(current.temperature);
                
                // Simple compliance risk logic: check if there is any measurable precipitation
                const isRaining = current.precipitation > 0.01; // Using a threshold
                const risk_level = isRaining ? "HIGH" : "LOW";
                const trigger_chance = isRaining ? Math.floor(Math.random() * (70 - 30) + 30) : Math.floor(Math.random() * 10);
                const rainfall_hourly = current.precipitation.toFixed(2);
                const time = new Date().toLocaleTimeString();

                weatherWidget.innerHTML = `
                    <div class="p-3 bg-teal-100 rounded-lg">
                        <p class="text-xs font-semibold text-teal-800">Forecast API Data (Live)</p>
                        <p class="text-xs text-teal-700">Last Synced: ${time} (Timezone: ${data.timezone})</p>
                    </div>
                    <div class="grid grid-cols-2 gap-3 text-center">
                        <div class="p-3 bg-slate-100 rounded-lg">
                            <p class="text-2xl font-bold text-slate-900">${temp}°F</p>
                            <p class="text-xs text-slate-600">Current Temp</p>
                        </div>
                        <div class="p-3 bg-slate-100 rounded-lg">
                            <p class="text-2xl font-bold text-slate-900">${rainfall_hourly} mm/hr</p>
                            <p class="text-xs text-slate-600">Current Precip. (NWS Mock)</p>
                        </div>
                    </div>
                    <div class="p-4 rounded-lg shadow-inner ${risk_level === 'HIGH' ? 'bg-red-200' : 'bg-green-200'}">
                        <p class="text-xl font-bold ${risk_level === 'HIGH' ? 'text-red-900' : 'text-green-900'}">${risk_level} COMPLIANCE RISK</p>
                        <p class="text-sm ${risk_level === 'HIGH' ? 'text-red-700' : 'text-green-700'} mt-1">
                            ${trigger_chance}% chance of Action Level Exceedance. StormGPT runs predictive analytics.
                        </p>
                    </div>
                `;

            } catch (error) {
                weatherWidget.innerHTML = `<p class="text-red-600 text-sm p-6 text-center">Weather Service Error: **Network Access Denied** (Try opening file directly in browser, or on GitHub).</p>`;
            }
        }
        
        function updateMap(lat, lon) {
            if (map) {
                map.setView([lat, lon], 13);
                // Clear any old drawn items when location changes
                drawnItems.clearLayers();
            } else {
                // Initialize map if it doesn't exist
                map = L.map('map-container').setView([lat, lon], 13);
                
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: 'Map data &copy; OpenStreetMap contributors'
                }).addTo(map);

                drawnItems = new L.FeatureGroup();
                map.addLayer(drawnItems);

                const drawControl = new L.Control.Draw({
                    edit: { featureGroup: drawnItems },
                    draw: {
                        polygon: { shapeOptions: { color: '#0d9488' }, allowIntersection: false, showArea: true },
                        polyline: false, rectangle: false, circle: false, marker: false, circlemarker: false
                    }
                });
                map.addControl(drawControl);

                map.on(L.Draw.Event.CREATED, function (event) {
                    drawnItems.addLayer(event.layer);
                    mapStatus.textContent = `Polygon (BMP Zone) created. Ready for GeoJSON export.`;
                });

                map.on(L.Draw.Event.EDITED, function () {
                    mapStatus.textContent = `BMP Zone edited. Ready for GeoJSON export.`;
                });
            }
            mapStatus.textContent = `Map centered on ${currentLocationName}. Use the tools to draw BMP zones.`;
        }
        
        function exportGeoJson() {
            const data = drawnItems.toGeoJSON();
            const jsonString = JSON.stringify(data, null, 2);

            if (data.features.length === 0) {
                 updateStatus(mapStatus, `ERROR: No features drawn. Draw a BMP polygon first!`, true);
                 return;
            }

            // Simulate file download (GeoJSON export)
            const blob = new Blob([jsonString], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `stormverse_bmp_data_${currentLocationName.replace(/[^a-zA-Z0-9]/g, '_')}.geojson`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            updateStatus(mapStatus, `GeoJSON exported successfully! Data ready for StormGPT analysis.`, false);
        }

        // --- EVENT HANDLERS ---
        applyLocationBtn.addEventListener('click', () => {
            const location = locationInput.value.trim();
            if (location) {
                geocodeLocation(location);
            } else {
                updateStatus(locationStatus, "Please enter a location.", true);
            }
        });

        locationInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                applyLocationBtn.click();
            }
        });

        updateWeatherBtn.addEventListener('click', () => fetchWeatherData(currentLat, currentLon));
        exportGeoJsonBtn.addEventListener('click', exportGeoJson);
        
        // --- Component Details Logic (from previous version) ---
        const detailTitle = document.getElementById('detail-title');
        const detailContent = document.getElementById('detail-content');
        const componentCards = document.querySelectorAll('.component-card');
        const workflowStepsContainer = document.getElementById('workflow-steps');
        const workflowDetailTitle = document.getElementById('workflow-detail-title');
        const workflowDetailContent = document.getElementById('workflow-detail-content');

        function updateComponentDetails(componentKey) {
            const data = componentData[componentKey];
            detailTitle.textContent = data.title;
            
            let contentHTML = `<p class="text-base font-medium mb-4">${data.description}</p>`;
            contentHTML += `<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">`;
            for (const key in data.features) {
                contentHTML += `
                    <div class="p-3 bg-teal-50 rounded-lg">
                        <h5 class="font-semibold text-teal-800 text-sm">${key}</h5>
                        <p class="text-xs text-teal-700">${data.features[key]}</p>
                    </div>
                `;
            }
            contentHTML += `</div>`;
            
            contentHTML += `<h4 class="text-lg font-bold text-slate-800 mt-6 mb-3">${componentKey === 'stormgpt' ? 'Autonomous Daemon Architecture' : 'Technical Breakdown'}</h4>`;
            contentHTML += `<ul class="space-y-3">`;

            if (componentKey === 'stormgpt') {
                contentHTML += data.subDetails.map(d => `
                    <li class="border-b border-slate-100 pb-2">
                        <span class="font-semibold text-slate-900">${d.name}:</span>
                        <span class="text-sm text-slate-700">${d.function}</span>
                        <span class="text-xs italic text-slate-500 block">Trigger: ${d.trigger}</span>
                    </li>
                `).join('');
            } else {
                 contentHTML += data.subDetails.map(d => `
                    <li class="border-b border-slate-100 pb-2">
                        <span class="font-semibold text-slate-900">${d.name}:</span>
                        <span class="text-sm text-slate-700">${d.function}</span>
                    </li>
                `).join('');
            }
            
            contentHTML += `</ul>`;

            detailContent.innerHTML = contentHTML;
        }

        componentCards.forEach(card => {
            card.addEventListener('click', (e) => {
                const key = e.currentTarget.dataset.component;
                updateComponentDetails(key);

                componentCards.forEach(c => c.classList.remove('border-teal-600', 'shadow-xl'));
                e.currentTarget.classList.add('border-teal-600', 'shadow-xl');
            });
        });

        // --- Workflow Steps Logic (from previous version) ---
        workflowData.forEach((step, index) => {
            const stepElement = document.createElement('button');
            stepElement.type = 'button';
            stepElement.dataset.step = index;
            stepElement.className = 'workflow-btn w-full text-left p-3 rounded-lg bg-white shadow-md hover:bg-teal-50 border-l-4 border-slate-200 transition duration-150';
            stepElement.innerHTML = `<span class="font-semibold text-slate-900">${index + 1}. ${step.title}</span>`;
            workflowStepsContainer.appendChild(stepElement);
        });

        document.querySelectorAll('.workflow-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const index = parseInt(e.currentTarget.dataset.step);
                const step = workflowData[index];

                document.querySelectorAll('.workflow-btn').forEach(b => {
                    b.classList.remove('border-teal-600', 'bg-teal-50');
                    b.classList.add('border-slate-200', 'bg-white');
                });
                
                e.currentTarget.classList.add('border-teal-600', 'bg-teal-50');
                e.currentTarget.classList.remove('border-slate-200', 'bg-white');

                workflowDetailTitle.textContent = step.title;
                workflowDetailContent.textContent = step.detail;
            });
        });

        // --- Chart.js Logic for Performance Metrics (from previous version) ---
        const perfCtx = document.getElementById('performanceChart').getContext('2d');
        const chartData = {
            labels: ['Report Generation', 'Compliance Analysis', 'NOAA Data Ingestion'],
            values: [120, 60, 30] // Max seconds
        };

        new Chart(perfCtx, {
            type: 'bar',
            data: {
                labels: chartData.labels,
                datasets: [{
                    label: 'Max Processing Time (Seconds)',
                    data: chartData.values,
                    backgroundColor: [
                        'rgba(13, 148, 136, 0.9)', 
                        'rgba(6, 78, 59, 0.8)', 
                        'rgba(15, 118, 110, 0.7)'
                    ],
                    borderColor: 'rgba(13, 148, 136, 1)',
                    borderWidth: 0,
                    borderRadius: 4,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    title: {
                        display: true,
                        text: 'Core Data Processing Speed (Worst Case, < Max Seconds)',
                        font: { size: 14, weight: 'bold' },
                        color: '#1e293b' 
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return ` < ${context.parsed.x} Seconds`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Time (Seconds)',
                            color: '#475569'
                        },
                        grid: {
                            color: 'rgba(200, 200, 200, 0.1)'
                        }
                    },
                    y: {
                        grid: { display: false }
                    }
                }
            }
        });

        // Initial setup
        document.addEventListener('DOMContentLoaded', () => {
            initMap();
            // Trigger initial geocoding for the default location set in the input field
            geocodeLocation(locationInput.value); 
            // Trigger default view
            document.querySelector('.component-card[data-component="stormverse"]').click(); 
        });
    </script>
</body>
</html>
